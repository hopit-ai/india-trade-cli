{
  "name": "india-trade",
  "productName": "India Trade",
  "version": "0.2.0",
  "description": "India Trade — macOS desktop app",
  "author": "Hopit AI",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "cd .. && python3 -m build --wheel -o macos-app/dist",
    "build": "electron-vite build && electron-builder --mac",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build:web": "electron-vite build && node scripts/build-web.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "ai.hopit.india-trade",
    "productName": "India Trade",
    "files": [
      "out/**/*",
      "build/icon.icns"
    ],
    "extraResources": [
      {
        "from": "dist/",
        "to": "python-pkg/",
        "filter": ["*.whl"]
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    }
  }
}
